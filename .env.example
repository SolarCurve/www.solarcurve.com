# Solar system phase — controls the Solar widget state
# Options: signed | permitted | installed | live
SOLAR_PHASE=live

# Steam API integration (for SteamWidget when ready)
STEAM_API_KEY=
STEAM_VANITY_URL=solarcurve

# Tesla Energy API (for live solar data, when SOLAR_PHASE=live)
TESLA_ENERGY_SITE_ID=
TESLA_ACCESS_TOKEN=
