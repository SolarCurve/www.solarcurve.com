---
// SolarWidget.astro
// Installation phases — update SOLAR_PHASE in env to advance the timeline:
//   "signed" | "permitted" | "installed" | "live"
// "live" fetches /api/solar client-side — a Cloudflare Worker (worker/) that
// proxies Tesla Fleet API live_status with token refresh and a 120s cache.

const phase = import.meta.env.SOLAR_PHASE ?? 'installed';
const phases = ['signed', 'permitted', 'installed', 'live'];
const currentIdx = phases.indexOf(phase);
---

<div class="widget-card h-full flex flex-col border-[#30230a]">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-solar-600 text-[15px]">☀</span>
    <span class="text-[11px] text-muted font-medium tracking-widest uppercase">Solar system</span>
  </div>

  {phase === 'live' ? (
    <div>
      <div class="flex items-baseline gap-2 mb-1">
        <span id="solar-kw" class="text-4xl font-medium text-solar-300">—</span>
        <span class="text-sm text-dim">kW live</span>
      </div>
      <p class="text-[11px] text-dim mb-3">of 28.9 kW peak · 65 panels · Flower Mound TX</p>
      <div class="grid grid-cols-2 gap-2 text-[11px]">
        <div class="bg-void rounded-lg p-2 border border-border">
          <p class="text-muted mb-0.5">Today's yield</p>
          <p id="today-kwh" class="font-medium text-bright">— kWh</p>
        </div>
        <div class="bg-void rounded-lg p-2 border border-border">
          <p class="text-muted mb-0.5">Peak today</p>
          <p id="peak-kw" class="font-medium text-solar-600">— kW</p>
        </div>
      </div>
      <script is:inline>
        (() => {
          const set = (id, text) => {
            const el = document.getElementById(id);
            if (el) el.textContent = text;
          };
          async function refresh() {
            try {
              const res = await fetch('/api/solar');
              if (!res.ok) return; // leave dashes on failure
              const d = await res.json();
              set('solar-kw', (d.solar_power_w / 1000).toFixed(1));
              if (d.today) {
                set('today-kwh', `${d.today.solar_kwh} kWh`);
                set('peak-kw', `${d.today.peak_kw} kW`);
              }
            } catch { /* leave dashes on failure */ }
          }
          refresh();
          setInterval(refresh, 120_000); // matches the worker's cache window
        })();
      </script>
    </div>
  ) : (
    <>
      <div class="flex items-baseline gap-2 mb-1">
        <span class="text-4xl font-medium text-solar-300">28.9</span>
        <span class="text-sm text-dim">kW DC</span>
      </div>
      <p class="text-[11px] text-dim mb-3">65 panels · 3 Tesla inverters · Flower Mound TX</p>

      <div class="grid grid-cols-4 gap-1 mb-2">
        {phases.map((p, i) => (
          <div>
            <div class={`h-0.5 rounded-full mb-1 ${i <= currentIdx ? 'bg-solar-600' : 'bg-border'}`}></div>
            <p class={`text-[9px] ${i <= currentIdx ? 'text-solar-600' : 'text-muted'} leading-tight`}>
              {p.charAt(0).toUpperCase() + p.slice(1)}
            </p>
          </div>
        ))}
      </div>
      {phase === 'installed' && (
        <p class="text-[10px] text-dim">Generating now · pending final inspection</p>
      )}
    </>
  )}

  <p class="text-[10px] text-muted text-right mt-auto pt-1">
    36,446 kWh/yr projected · 114% offset
  </p>
</div>
