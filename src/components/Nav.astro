---
// shortLabel is used below the sm breakpoint, where the full labels
// overflow a 375px viewport.
const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/gaming', label: 'Gaming' },
  { href: '/solar', label: 'Solar journey', shortLabel: 'Solar' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="border-b border-border px-6 md:px-10 h-14 flex items-center justify-between relative z-20 bg-void/80 backdrop-blur-sm">
  <a href="/" class="flex items-center gap-2.5 group">
    <div class="w-7 h-7 rounded-lg bg-solar-600 flex items-center justify-center text-white text-sm flex-shrink-0">
      ☀
    </div>
    <span class="text-[15px] font-medium text-star">SolarCurve</span>
    <span class="text-sm text-muted hidden sm:inline">/ House of Flamp</span>
  </a>

  <div class="flex items-center gap-4 sm:gap-6">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`text-sm whitespace-nowrap transition-colors duration-100 ${
          currentPath.startsWith(link.href)
            ? 'text-solar-300'
            : 'text-dim hover:text-bright'
        }`}
      >
        {link.shortLabel ? (
          <>
            <span class="sm:hidden">{link.shortLabel}</span>
            <span class="hidden sm:inline">{link.label}</span>
          </>
        ) : link.label}
      </a>
    ))}
  </div>
</nav>
