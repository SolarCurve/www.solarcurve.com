---
// Hero.astro — live NASA SDO solar photography background
// Image: Solar Dynamics Observatory AIA 171 (extreme UV, 1 MK corona)
// Updated every ~15 minutes by NASA. Public domain — U.S. government work.
---

<section class="relative overflow-hidden" style="height: 340px;">
  <!-- Live NASA solar image — updated every ~15 min by the SDO -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('https://sdo.gsfc.nasa.gov/assets/img/latest/latest_1024_0171.jpg');"
    aria-hidden="true"
  ></div>

  <!-- Dark overlay for left-side text readability -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to right, rgba(13,17,23,0.82) 0%, rgba(13,17,23,0.55) 45%, rgba(13,17,23,0.1) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Bottom fade into page -->
  <div
    class="absolute bottom-0 left-0 right-0"
    style="height: 80px; background: linear-gradient(to bottom, transparent, #0d1117);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 px-6 md:px-10 pt-14 pb-0">
    <p class="text-[11px] font-medium tracking-widest uppercase text-solar-300 mb-2">
      SolarCurve · since 2000
    </p>
    <h1 class="text-4xl md:text-5xl font-medium text-white leading-tight mb-4" style="text-shadow: 0 2px 20px rgba(0,0,0,0.8);">
      House of Flamp
    </h1>
    <p class="text-sm text-bright leading-relaxed max-w-lg" style="text-shadow: 0 1px 8px rgba(0,0,0,0.9);">
      Founder of TAU esports · Photo retouching artisan · Tech company founder ·
      Now generating more electricity than I use. Flower Mound, TX.
    </p>
  </div>
</section>
