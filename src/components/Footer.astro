---
const year = new Date().getFullYear();
---

<footer class="border-t border-border px-6 md:px-10 py-5 flex items-center justify-between">
  <span class="text-[11px] text-muted">
    © {year} SolarCurve · House of Flamp · Flower Mound, TX
  </span>
  <div class="flex items-center gap-4">
    <a
      href="https://steamcommunity.com/id/solarcurve"
      target="_blank"
      rel="noopener noreferrer"
      class="text-muted hover:text-bright transition-colors text-sm"
      aria-label="Steam profile"
    >Steam</a>
    <a
      href="https://github.com/SolarCurve"
      target="_blank"
      rel="noopener noreferrer"
      class="text-muted hover:text-bright transition-colors text-sm"
      aria-label="GitHub profile"
    >GitHub</a>
    <a
      href="https://solarcurve.blogspot.com"
      target="_blank"
      rel="noopener noreferrer"
      class="text-muted hover:text-bright transition-colors text-sm"
      aria-label="Old blog archive"
    >Archive</a>
  </div>
</footer>
