---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "House of Flamp",
  description = "SolarCurve's personal blog. Esports founder, tech company builder, solar power enthusiast, lifelong gamer. Flower Mound, TX.",
  ogImage = "/og-default.png",
} = Astro.props;

const siteName = "SolarCurve";
const fullTitle = title === "House of Flamp" ? `${siteName}'s ${title}` : `${title} — ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body class="bg-void min-h-screen">
    <!-- Password gate overlay -->
    <div id="sc-gate" style="display:none; position:fixed; inset:0; z-index:9999; background:#0d1117; align-items:center; justify-content:center; flex-direction:column; gap:1.5rem;">
      <div style="text-align:center; max-width:320px; width:100%; padding:0 1.5rem;">
        <p style="font-size:11px; letter-spacing:0.15em; text-transform:uppercase; color:#f97316; margin-bottom:1.5rem; font-family:'Inter',sans-serif;">SolarCurve · private</p>
        <h1 style="font-size:1.5rem; font-weight:500; color:#e6edf3; margin-bottom:0.5rem; font-family:'Inter',sans-serif;">House of Flamp</h1>
        <p style="font-size:0.8rem; color:#8b949e; margin-bottom:2rem; font-family:'Inter',sans-serif;">This site is private. Enter the access code to continue.</p>
        <form id="sc-form" style="display:flex; flex-direction:column; gap:0.75rem;">
          <input
            id="sc-input"
            type="password"
            placeholder="Access code"
            autocomplete="off"
            style="width:100%; padding:0.65rem 1rem; background:#161b22; border:1px solid #30363d; border-radius:6px; color:#e6edf3; font-size:0.9rem; font-family:'Inter',sans-serif; outline:none; box-sizing:border-box;"
          />
          <button
            type="submit"
            style="width:100%; padding:0.65rem 1rem; background:#f97316; border:none; border-radius:6px; color:#fff; font-size:0.875rem; font-weight:500; font-family:'Inter',sans-serif; cursor:pointer;"
          >Enter</button>
        </form>
        <p id="sc-err" style="font-size:0.78rem; color:#f85149; margin-top:0.75rem; display:none; font-family:'Inter',sans-serif;">Incorrect code. Try again.</p>
      </div>
    </div>

    <div id="sc-content" style="display:none;">
      <slot />
    </div>

    <script>
    (function() {
      // SHA-256 of "Solar27" — passphrase never stored in plaintext
      const HASH = '4984a9eb0dac3811fc5ed4bacbf067aa79eca131ddd8a198601e42f9f8d4ef9e';

      async function sha256(str) {
        const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
        return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
      }

      function getCookie(name) {
        return document.cookie.split(';').map(c => c.trim()).find(c => c.startsWith(name + '='))?.split('=')[1];
      }

      function unlock() {
        document.getElementById('sc-gate').style.display = 'none';
        document.getElementById('sc-content').style.display = 'block';
      }

      function lock() {
        document.getElementById('sc-gate').style.display = 'flex';
        document.getElementById('sc-content').style.display = 'none';
      }

      // Check existing auth cookie
      if (getCookie('sc_auth') === '1') {
        unlock();
      } else {
        lock();
      }

      document.getElementById('sc-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const val = document.getElementById('sc-input').value.trim();
        const hash = await sha256(val);
        if (hash === HASH) {
          // Set 30-day cookie
          const exp = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toUTCString();
          document.cookie = `sc_auth=1; expires=${exp}; path=/; SameSite=Lax`;
          document.getElementById('sc-err').style.display = 'none';
          unlock();
        } else {
          document.getElementById('sc-err').style.display = 'block';
          document.getElementById('sc-input').value = '';
          document.getElementById('sc-input').focus();
        }
      });
    })();
    </script>
  </body>
</html>
